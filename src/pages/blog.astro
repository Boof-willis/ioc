---
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import A2PCompliance from '@/components/A2PCompliance.astro';
import '@/styles/global.css';

const upcomingTopics = [
  {
    category: "Sports Medicine",
    title: "How to know if an injury needs an X-ray vs. ice and rest",
    description: "A practical guide to the warning signs that mean it's time to see an orthopedic specialist instead of waiting it out.",
  },
  {
    category: "Sports Medicine",
    title: "Return-to-play timelines: what's realistic after common injuries",
    description: "Sprains, strains, fractures, and post-surgical recovery—what the data actually says about safe return windows.",
  },
  {
    category: "Joint Health",
    title: "Knee pain in adults over 40: when it's arthritis and when it's not",
    description: "Differentiating mechanical knee pain from inflammatory and degenerative causes, and what each type usually responds to.",
  },
  {
    category: "Patient Resources",
    title: "Urgent care vs. ER vs. orthopedic urgent care: where should you go?",
    description: "A breakdown by injury type, cost, wait time, and provider expertise so you can make the right call in the moment.",
  },
  {
    category: "Pediatric Orthopedics",
    title: "Growth plate injuries in young athletes: what parents need to know",
    description: "Why kids' injuries aren't just smaller adult injuries, and the red flags that warrant same-day evaluation.",
  },
  {
    category: "Preventive Care",
    title: "The case for an annual sports physical—even for adult recreational athletes",
    description: "How a structured musculoskeletal evaluation can catch issues before they sideline you for the season.",
  },
];

const categories = [
  { name: "Sports Medicine", count: 12 },
  { name: "Joint Health", count: 8 },
  { name: "Injury Recovery", count: 10 },
  { name: "Pediatric Orthopedics", count: 5 },
  { name: "Preventive Care", count: 6 },
  { name: "Patient Resources", count: 7 },
];
---

<html lang="en">
  <head>
    <!-- Google Tag Manager -->
    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-52DJTWGN');</script>
    <!-- End Google Tag Manager -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="index, follow" />
    <meta name="description" content="Orthopedic and sports medicine education from Instant Orthopedic Care in Draper, Utah. Patient-friendly articles on injury recovery, joint health, and when to seek same-day care." />
    <title>Orthopedic Blog & Patient Education | Instant Orthopedic Care</title>
    <link rel="canonical" href="https://instantorthocare.com/blog" />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="Instant Orthopedic Care" />
    <meta property="og:title" content="Orthopedic Blog & Patient Education | Instant Orthopedic Care" />
    <meta property="og:description" content="Patient-friendly orthopedic and sports medicine education from the team at Instant Orthopedic Care in Draper, Utah." />
    <meta property="og:url" content="https://instantorthocare.com/blog" />
    <meta property="og:image" content="https://cdn.midjourney.com/fbffde7d-2121-487d-ab23-a9dc0cad2adc/0_3.png" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Orthopedic Blog & Patient Education | Instant Orthopedic Care" />
    <meta name="twitter:description" content="Patient education from the team at Instant Orthopedic Care." />

    <meta name="geo.region" content="US-UT" />
    <meta name="geo.placename" content="Draper, Utah" />

    <link rel="icon" type="image/x-icon" href="/favicon/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon/favicon-96x96.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
    <link rel="manifest" href="/favicon/site.webmanifest" />
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <A2PCompliance />
  </head>
  <body class="bg-white text-slate-900 font-sans antialiased selection:bg-blue-500 selection:text-white">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-52DJTWGN"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <Header />

    <!-- Hero -->
    <Section background="white" class="pt-32 pb-16 relative overflow-hidden">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[500px] bg-blue-100/40 rounded-full blur-[120px] pointer-events-none"></div>
      <Container class="relative z-10">
        <div class="max-w-3xl">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-50 border border-blue-100 text-blue-700 text-[10px] font-bold uppercase tracking-widest mb-6">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-blue-500"></span>
            </span>
            Patient Education
          </div>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-slate-900 tracking-tight mb-6 leading-[1.05]">
            Orthopedic & Sports Medicine <span class="text-blue-600">Education</span>
          </h1>
          <p class="text-lg md:text-xl text-slate-500 leading-relaxed max-w-2xl mb-4">
            Straightforward, clinically grounded answers to the questions patients ask us every day. Written by the providers at Instant Orthopedic Care to help you make better decisions about injuries, recovery, and when to be seen.
          </p>
          <p class="text-base text-slate-500 leading-relaxed max-w-2xl">
            New articles publish regularly. Have a topic you'd like us to cover? <a href="mailto:info@instantorthocare.com" class="text-blue-600 font-semibold hover:text-blue-700 transition-colors">Email the clinic</a>.
          </p>
        </div>
      </Container>
    </Section>

    <!-- Coming Soon Notice -->
    <Section background="white" class="pb-12">
      <Container>
        <div class="max-w-4xl mx-auto bg-gradient-to-br from-blue-50 to-slate-50 border border-blue-100 rounded-3xl p-8 md:p-12">
          <div class="flex flex-col md:flex-row items-start md:items-center gap-6">
            <div class="flex-shrink-0 w-14 h-14 rounded-2xl bg-blue-600 text-white flex items-center justify-center shadow-lg shadow-blue-600/25">
              <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" /></svg>
            </div>
            <div class="flex-1">
              <h2 class="text-2xl md:text-3xl font-bold text-slate-900 tracking-tight mb-2">Articles publishing soon</h2>
              <p class="text-slate-600 leading-relaxed">
                Our providers are putting the finishing touches on a library of patient-friendly articles covering everything from acute injury triage to long-term joint health. Check back soon, or call <a href="tel:3853867026" class="text-blue-600 font-semibold hover:text-blue-700 transition-colors">(385) 386-7026</a> if you have an immediate question we can answer in person.
              </p>
            </div>
          </div>
        </div>
      </Container>
    </Section>

    <!-- Upcoming Topics -->
    <Section background="white" class="py-16">
      <Container>
        <div class="max-w-6xl mx-auto">
          <div class="mb-12">
            <h2 class="text-3xl md:text-4xl font-bold text-slate-900 tracking-tight mb-3">Topics on the way</h2>
            <p class="text-lg text-slate-500 max-w-2xl">A preview of what's coming to the IOC education library.</p>
          </div>

          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            {upcomingTopics.map((post) => (
              <article class="rounded-2xl p-8 border border-slate-100 bg-white hover:border-blue-200 hover:shadow-[0_10px_40px_-5px_rgba(59,130,246,0.15)] transition-all duration-300 group">
                <span class="inline-block text-xs font-bold text-blue-600 uppercase tracking-widest mb-4">{post.category}</span>
                <h3 class="text-lg font-bold text-slate-900 mb-3 leading-snug">{post.title}</h3>
                <p class="text-sm text-slate-500 leading-relaxed mb-5">{post.description}</p>
                <span class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Coming soon</span>
              </article>
            ))}
          </div>
        </div>
      </Container>
    </Section>

    <!-- Categories -->
    <Section background="gray" class="py-20">
      <Container>
        <div class="max-w-4xl mx-auto text-center">
          <h2 class="text-3xl md:text-4xl font-bold text-slate-900 tracking-tight mb-4">Categories</h2>
          <p class="text-lg text-slate-500 mb-10 max-w-2xl mx-auto">
            Articles will be organized by topic so you can jump straight to what's relevant to your situation.
          </p>
          <div class="flex flex-wrap justify-center gap-3">
            {categories.map((cat) => (
              <span class="inline-flex items-center gap-2 px-5 py-2.5 bg-white border border-slate-100 text-slate-700 text-sm font-semibold rounded-full shadow-sm">
                {cat.name}
              </span>
            ))}
          </div>
        </div>
      </Container>
    </Section>

    <!-- CTA -->
    <Section background="white" class="py-24">
      <Container>
        <div class="bg-slate-900 rounded-[3rem] p-12 md:p-20 text-center relative overflow-hidden shadow-2xl">
          <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[400px] bg-blue-600/20 rounded-full blur-[120px] pointer-events-none"></div>
          <div class="relative z-10 max-w-2xl mx-auto">
            <h2 class="text-3xl md:text-5xl font-bold text-white tracking-tight mb-6">Don't wait on an article.<br/><span class="text-blue-400">Talk to a provider today.</span></h2>
            <p class="text-slate-400 text-lg md:text-xl mb-10 leading-relaxed">If something hurts and you're not sure what to do, we can answer it in person—usually in under 15 minutes.</p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <a href="https://pp-wfe-101.advancedmd.com/163338/onlineintake/demographic" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-8 py-4 bg-blue-600 text-white font-bold rounded-full hover:bg-blue-500 hover:shadow-lg hover:shadow-blue-600/30 transition-all transform hover:-translate-y-1">Check In Now</a>
              <a href="tel:3853867026" class="inline-flex items-center justify-center px-8 py-4 bg-white/5 text-white font-bold rounded-full hover:bg-white/10 transition-colors border border-white/10 backdrop-blur-sm">Call (385) 386-7026</a>
            </div>
          </div>
        </div>
      </Container>
    </Section>

    <Footer />
  </body>
</html>
