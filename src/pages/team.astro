          "memberOf": {
            "@type": "MedicalOrganization",
            "name": "Instant Orthopedic Care"
          }
        },
        {
          "@type": "Physician",
          "name": "Dr. Christian Sybowsky",
          "jobTitle": "Orthopedic Physician",
          "medicalSpecialty": ["Orthopedic Surgery", "Sports Medicine"],
          "description": "Board-certified orthopedic physician with fellowship training in sports medicine, specializing in fracture care and non-operative management.",
          "image": "https://instantorthopediccare.com/images/dr-christian-sybowsky-md.webp",
          "memberOf": {
            "@type": "MedicalOrganization",
            "name": "Instant Orthopedic Care"
          }
        },
        {
          "@type": "Physician",
