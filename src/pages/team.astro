---
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import '@/styles/global.css';

// Team members data
const doctors = [
  {
    name: "Dr. James R. Meadows",
    title: "Orthopedic Surgeon",
    credentials: "MD",
    image: "/images/dr-james-r-meadows-md.webp",
    bio: "Dr. James R. Meadows is a board-certified, fellowship-trained orthopedic surgeon specializing in sports medicine and musculoskeletal care. He earned his medical degree from The Ohio State University College of Medicine, completed his orthopedic surgery residency at the University of Texas Health Science Center at San Antonio, and completed fellowship training in sports medicine at Tahoe Orthopedics and Sports Medicine. His training and clinical experience include advanced arthroscopic procedures, ligament reconstruction, joint preservation, and comprehensive care for sports-related and degenerative orthopedic conditions. Dr. Meadows is known for his evidence-based approach and commitment to high clinical standards.",
    specialties: ["Sports Medicine", "Joint Preservation", "Ligament Reconstruction"],
  },
  {
    name: "Dr. Christian Sybowsky",
    title: "Orthopedic Physician",
    credentials: "MD",
    image: "/images/dr-christian-sybowsky-md.webp",
    bio: "Dr. Christian Sybowsky is a board-certified orthopedic physician with fellowship training in sports medicine. He earned his medical degree from the University of Utah School of Medicine, completed his orthopedic surgery residency at the University of Washington, and completed fellowship training in orthopedic sports medicine at the University of Iowa Hospitals and Clinics. His clinical background includes fracture care, sports-related injuries, joint conditions, and non-operative orthopedic management. Dr. Sybowsky is known for a patient-centered approach that emphasizes clear communication, timely diagnosis, and evidence-based treatment.",
    specialties: ["Sports Medicine", "Fracture Care", "Non-operative Management"],
  },
];

const providers = [
  {
    name: "McKay Milne",
    title: "Physician Assistant",
    credentials: "PA-C",
    image: "/images/mckay-milne-pa-c.webp",
    bio: "McKay Milne, PA-C is an orthopedic Physician Assistant with a strong focus in sports medicine and musculoskeletal injury care. He specializes in evaluating and treating acute and chronic orthopedic conditions, including the use of diagnostic ultrasound and ultrasound-guided procedures. At Instant Orthopedic Care, McKay is committed to helping patients return to activity quickly through accurate diagnosis and efficient, evidence-based care.",
    specialties: ["Sports Medicine", "Diagnostic Ultrasound", "Musculoskeletal Care"],
  },
  {
    name: "Cole Mitchell",
    title: "Physician Assistant",
    credentials: "PA-C",
    image: "/images/cole-mitchell-pa-c.webp",
    bio: "Cole Mitchell, PA-C is an orthopedic Physician Assistant with a strong focus in sports medicine and musculoskeletal injury care. He has extensive experience evaluating and treating orthopedic conditions including fractures, acute injuries, and sports-related complaints, as well as performing injections and assisting with orthopedic procedures. At Instant Orthopedic Care, Cole is focused on accurate diagnosis, efficient treatment, and helping patients return to activity as quickly and safely as possible.",
    specialties: ["Fractures & Acute Injuries", "Sports Medicine", "Injections"],
  },
  {
    name: "Nate Littlefield",
    title: "Nurse Practitioner",
    credentials: "FNP-C",
    image: "/images/nate-littlefield-fnp-c.png",
    imagePosition: "object-[center_25%]",
    bio: "Nate Littlefield, FNP-C is an orthopedic Nurse Practitioner with a strong focus on sports medicine and musculoskeletal injury care. He has extensive experience evaluating and treating fractures, acute sports injuries, ligament and tendon injuries, and other orthopedic conditions affecting active patients. Nate is skilled in injury evaluation, imaging interpretation, bracing, injections, and non-surgical treatment strategies designed to get patients moving again quickly and safely. At Instant Orthopedic Care, Nate focuses on rapid diagnosis, efficient treatment, and helping athletes and active individuals return to work, sports, and daily activity as quickly as possible.",
    specialties: ["Sports Medicine", "Fracture Care", "Injections & Bracing"],
  },
];
---

<html lang="en">
  <head>
