      "name": "Instant Orthopedic Care",
      "url": "https://instantorthopediccare.com/team",
      "telephone": "+1-385-386-7026",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "75 E 12300 S Suite 100",
        "addressLocality": "Draper",
        "addressRegion": "UT",
        "postalCode": "84020",
        "addressCountry": "US"
      },
      "medicalSpecialty": "Orthopedic",
      "member": [
        {
          "@type": "Physician",
          "name": "Dr. James R. Meadows",
          "jobTitle": "Orthopedic Surgeon",
          "medicalSpecialty": ["Orthopedic Surgery", "Sports Medicine"],
          "description": "Board-certified, fellowship-trained orthopedic surgeon specializing in sports medicine, ligament reconstruction, and joint preservation.",
