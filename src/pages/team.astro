  </head>
  <body class="bg-white">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-52DJTWGN"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <Header />
    
    <!-- Hero Section -->
    <Section background="white" class="pt-32 pb-24 relative overflow-hidden">
      
      <Container class="relative z-10">
        <div class="text-center max-w-3xl mx-auto">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-50 border border-blue-100 text-blue-600 font-bold text-[10px] uppercase tracking-widest mb-6">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-blue-500"></span>
            </span>
            World-Class Care
          </div>
          
          <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-slate-900 tracking-tight mb-8 leading-[0.95]">
            Meet the <span class="text-blue-600">Experts.</span>
          </h1>
          <p class="text-xl md:text-2xl text-slate-500 leading-relaxed font-medium max-w-2xl mx-auto">
            Our board-certified specialists and experienced providers are dedicated to getting you back to what you love—faster.
          </p>
        </div>
      </Container>
    </Section>

    <!-- Doctors Section -->
    <Section background="gray" class="py-24">
      <Container>
        <div class="mb-16 flex flex-col md:flex-row md:items-end justify-between gap-4">
          <div>
            <h2 class="text-3xl md:text-4xl font-bold text-slate-900 tracking-tight mb-3">Orthopedic Physicians</h2>
            <p class="text-lg text-slate-500 max-w-xl">Board-certified specialists with decades of combined experience in sports medicine, surgery, and joint reconstruction.</p>
          </div>
        </div>
        
        <div class="flex flex-col gap-8">
          {doctors.map((doctor) => (
            <div class="bg-white rounded-[2.5rem] border border-slate-100/60 shadow-xl shadow-slate-200/40 overflow-hidden hover:shadow-2xl hover:shadow-blue-900/5 hover:border-blue-100 transition-all duration-500 group">
              <div class="flex flex-col md:flex-row items-stretch">
                <!-- Image -->
                <div class="md:w-2/5 lg:w-1/3 min-h-[320px] relative overflow-hidden">
                  <img 
                    src={doctor.image} 
                    alt={`${doctor.name}, ${doctor.credentials} – ${doctor.title} at Instant Orthopedic Care in Draper, Utah`}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 absolute inset-0"
                  />
                  <!-- Overlay for text legibility on mobile if needed, though we stack -->
                  <div class="absolute inset-0 bg-gradient-to-t from-black/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                </div>
                
                <!-- Content -->
                <div class="md:w-3/5 lg:w-2/3 p-8 md:p-12 flex flex-col justify-center">
                  <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-4 mb-6">
                    <div>
                      <h3 class="text-3xl font-bold text-slate-900 tracking-tight mb-2 group-hover:text-blue-600 transition-colors">{doctor.name}</h3>
                      <div class="flex flex-wrap items-center gap-3 text-sm">
                         <span class="font-bold text-blue-600 bg-blue-50 px-3 py-1 rounded-full">{doctor.credentials}</span>
                         <span class="text-slate-500 font-medium border-l border-slate-200 pl-3">{doctor.title}</span>
                      </div>
                    </div>
                  </div>
                  
                  <p class="text-slate-600 text-sm leading-relaxed mb-8 max-w-3xl">
                    {doctor.bio}
                  </p>
                  
                  <div>
                    <p class="text-[11px] font-bold text-slate-400 uppercase tracking-widest mb-3">Specialties</p>
                    <div class="flex flex-wrap gap-2">
                      {doctor.specialties.map((specialty) => (
                        <span class="inline-flex items-center px-4 py-2 bg-slate-50 border border-slate-100 text-slate-700 text-sm font-semibold rounded-full hover:bg-white hover:border-blue-200 hover:text-blue-600 transition-all duration-300">
                          {specialty}
                        </span>
                      ))}
                    </div>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </Container>
    </Section>

    <!-- Advanced Practice Providers Section -->
    <Section background="white" class="py-24">
      <Container>
        <div class="mb-16">
          <h2 class="text-3xl md:text-4xl font-bold text-slate-900 tracking-tight mb-3">Advanced Practice Providers</h2>
          <p class="text-lg text-slate-500 max-w-xl">Skilled providers delivering expert orthopedic care, casting, and rehabilitation support.</p>
        </div>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {providers.map((pa) => (
            <div class="bg-slate-50 rounded-[1.75rem] border border-slate-100 overflow-hidden hover:shadow-xl hover:shadow-slate-200/50 hover:bg-white hover:border-blue-100 transition-all duration-300 group">
              <div class="flex flex-col h-full">
                <!-- Header with Image -->
                <div class="p-1.5">
                  <div class="relative h-72 w-full overflow-hidden rounded-[1.25rem]">
                    <img 
                      src={pa.image} 
                      alt={`${pa.name}, ${pa.credentials} – ${pa.title} at Instant Orthopedic Care in Draper, Utah`}
                      class={`w-full h-full object-cover ${pa.imagePosition || 'object-top'} group-hover:scale-105 transition-transform duration-700`}
                    />
                  </div>
                </div>
                
                <!-- Content -->
                <div class="p-6 pt-4 flex-1 flex flex-col">
                  <div class="mb-4">
                    <div class="flex items-center justify-between mb-1.5">
                       <h3 class="text-lg font-bold text-slate-900 tracking-tight group-hover:text-blue-600 transition-colors">{pa.name}</h3>
                       <span class="text-blue-600 font-bold bg-blue-100/50 px-2.5 py-0.5 rounded-full text-[10px]">{pa.credentials}</span>
                    </div>
                    <p class="text-slate-500 font-medium text-xs">{pa.title}</p>
                  </div>
                  
                  <p class="text-slate-600 leading-relaxed mb-6 text-xs flex-1">
                    {pa.bio}
                  </p>
                  
                  <div class="pt-4 border-t border-slate-200/50">
                    <div class="flex flex-wrap gap-1.5">
                      {pa.specialties.map((specialty) => (
                        <span class="inline-block px-2.5 py-1 bg-white border border-slate-200 text-slate-600 text-[11px] font-semibold rounded-full group-hover:border-blue-200 group-hover:text-blue-600 transition-colors">
                          {specialty}
                        </span>
                      ))}
                    </div>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </Container>
    </Section>

    <!-- Simple CTA -->
    <Section background="white" class="pb-24 pt-0">
      <Container>
        <div class="bg-slate-900 rounded-[3rem] p-12 md:p-20 text-center relative overflow-hidden shadow-2xl">
          <!-- Glow effect -->
          <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[400px] bg-blue-600/20 rounded-full blur-[120px] pointer-events-none"></div>
          
          <div class="relative z-10 max-w-2xl mx-auto">
            <h2 class="text-3xl md:text-5xl font-bold text-white tracking-tight mb-6">
              Skip the ER. <br/><span class="text-blue-400">See a specialist today.</span>
            </h2>
            <p class="text-slate-400 text-lg md:text-xl mb-10 leading-relaxed">
              Same-day appointments available for fractures, sprains, and sports injuries.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <a href="https://pp-wfe-101.advancedmd.com/163338/onlineintake/demographic" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-8 py-4 bg-blue-600 text-white font-bold rounded-full hover:bg-blue-500 hover:shadow-lg hover:shadow-blue-600/30 transition-all transform hover:-translate-y-1">
                Check In Now
              </a>
              <a href="tel:3853867026" class="inline-flex items-center justify-center px-8 py-4 bg-white/5 text-white font-bold rounded-full hover:bg-white/10 transition-colors border border-white/10 backdrop-blur-sm">
                Call (385) 386-7026
              </a>
            </div>
          </div>
        </div>
      </Container>
    </Section>

    <Footer />
  </body>
</html>
