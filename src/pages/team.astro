    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-52DJTWGN');</script>
    <!-- End Google Tag Manager -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="index, follow" />
    <meta name="description" content="Meet the board-certified orthopedic surgeons and physician assistants at Instant Orthopedic Care in Draper, UT. Fellowship-trained specialists in sports medicine, fracture care & joint preservation." />
    <title>Our Orthopedic Specialists & Providers | Instant Orthopedic Care – Draper, UT</title>
    <link rel="canonical" href="https://instantorthopediccare.com/team" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="Instant Orthopedic Care" />
    <meta property="og:title" content="Our Orthopedic Specialists & Providers | Instant Orthopedic Care" />
    <meta property="og:description" content="Board-certified orthopedic surgeons and experienced physician assistants specializing in sports medicine, fracture care, and musculoskeletal treatment in Draper, Utah." />
    <meta property="og:url" content="https://instantorthopediccare.com/team" />
    <meta property="og:image" content="https://cdn.midjourney.com/fbffde7d-2121-487d-ab23-a9dc0cad2adc/0_3.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Orthopedic care team at Instant Orthopedic Care in Draper, Utah" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Our Orthopedic Specialists & Providers | Instant Orthopedic Care" />
    <meta name="twitter:description" content="Board-certified orthopedic surgeons and physician assistants in Draper, UT. Fellowship-trained in sports medicine, fracture care & joint preservation." />
    <meta name="twitter:image" content="https://cdn.midjourney.com/fbffde7d-2121-487d-ab23-a9dc0cad2adc/0_3.png" />
    <meta name="twitter:image:alt" content="Orthopedic care team at Instant Orthopedic Care in Draper, Utah" />
    
    <!-- Favicons -->
    <link rel="icon" type="image/x-icon" href="/favicon/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon/favicon-96x96.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
    <link rel="manifest" href="/favicon/site.webmanifest" />

    <!-- Schema.org JSON-LD – Medical Organization with Physicians -->
    <script type="application/ld+json">
