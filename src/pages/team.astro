            "name": "Instant Orthopedic Care"
          }
        },
        {
          "@type": "Physician",
          "name": "Cole Mitchell",
          "jobTitle": "Physician Assistant (PA-C)",
          "medicalSpecialty": ["Sports Medicine", "Fracture Care"],
          "description": "Orthopedic physician assistant with extensive experience in fractures, acute injuries, sports medicine, and injection procedures.",
          "image": "https://instantorthopediccare.com/images/cole-mitchell-pa-c.webp",
          "memberOf": {
            "@type": "MedicalOrganization",
            "name": "Instant Orthopedic Care"
          }
        },
        {
          "@type": "Physician",
          "name": "Nate Littlefield",
          "jobTitle": "Nurse Practitioner (FNP-C)",
          "medicalSpecialty": ["Sports Medicine", "Musculoskeletal Care"],
          "description": "Orthopedic nurse practitioner specializing in sports medicine, fracture care, imaging interpretation, injections, and non-surgical treatment strategies.",
          "image": "https://instantorthopediccare.com/images/nate-littlefield-fnp-c.png",
          "memberOf": {
            "@type": "MedicalOrganization",
            "name": "Instant Orthopedic Care"
          }
        }
      ]
    }
