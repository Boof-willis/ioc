        <script>
          (function() {
            const scrollContainer = document.getElementById('insurance-pills-scroll');
            if (!scrollContainer) return;
            
            function updateMask() {
              const scrollLeft = scrollContainer.scrollLeft;
              const scrollWidth = scrollContainer.scrollWidth;
              const clientWidth = scrollContainer.clientWidth;
              const maxScroll = scrollWidth - clientWidth;
              
              // Determine if we need left fade (scrolled right)
              const needsLeftFade = scrollLeft > 10; // Small threshold to avoid flicker
              // Determine if we need right fade (more content to scroll)
              const needsRightFade = scrollLeft < maxScroll - 10; // Small threshold
              
              let maskGradient = '';
              
              if (needsLeftFade && needsRightFade) {
                // Both fades needed
                maskGradient = 'linear-gradient(to right, transparent 0%, black 8%, black 87%, transparent 100%)';
              } else if (needsLeftFade) {
                // Only left fade (at end)
                maskGradient = 'linear-gradient(to right, transparent 0%, black 8%, black 100%)';
              } else if (needsRightFade) {
                // Only right fade (at start)
                maskGradient = 'linear-gradient(to right, black 0%, black 87%, transparent 100%)';
              } else {
                // No fades needed (shouldn't happen, but just in case)
                maskGradient = 'linear-gradient(to right, black 0%, black 100%)';
              }
              
              scrollContainer.style.maskImage = maskGradient;
              scrollContainer.style.webkitMaskImage = maskGradient;
            }
            
            // Initial update
            updateMask();
            
            // Update on scroll
            scrollContainer.addEventListener('scroll', updateMask);
            
            // Update on resize (in case container size changes)
            window.addEventListener('resize', updateMask);
          })();
        </script>

