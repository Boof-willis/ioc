    <!-- Wait Time Logic -->
    <script>
      function updateWaitTime() {
        const now = new Date();
        // Get 30-minute interval index
        const interval = Math.floor(now.getTime() / (30 * 60 * 1000));
        
        // Use interval as seed for pseudo-random number
        // Simple seeded random function
        const seed = interval;
        const x = Math.sin(seed) * 10000;
        const random = x - Math.floor(x);
        
        // Range 5-16
        const waitTime = Math.floor(random * (16 - 5 + 1)) + 5;
        
        const el = document.getElementById('wait-time-val');
        if (el) {
            el.textContent = waitTime.toString();
        }
      }

      // Initial update
      updateWaitTime();
      
      // Check every minute if we crossed a 30-min boundary
      setInterval(updateWaitTime, 60000);
    </script>
