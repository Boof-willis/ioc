    <!-- FAQPage Schema -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Do I need an appointment or referral to visit your Draper clinic?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No. Our walk-in orthopedic clinic in Draper, UT welcomes patients during all business hours—no appointment or referral needed. You can also check in online to save time."
          }
        },
        {
          "@type": "Question",
          "name": "What insurance do you accept?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "We accept most major insurance plans including Blue Cross Blue Shield, UnitedHealthcare, Aetna, Cigna, SelectHealth, Medicare, Medicaid, and workers' compensation. Call (385) 386-7026 if you're unsure about your specific plan."
          }
        },
        {
          "@type": "Question",
          "name": "How much does orthopedic urgent care cost vs. the ER?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Our orthopedic urgent care visits cost up to 75% less than an emergency room visit. With insurance, you'll pay your standard specialist copay. Without insurance, visits typically range from $200–$400 with transparent pricing upfront."
          }
        },
        {
          "@type": "Question",
          "name": "What orthopedic conditions do you treat?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "We treat all musculoskeletal injuries and conditions including fractures, sprains, dislocations, sports injuries, ligament tears, arthritis, chronic joint pain, and work-related injuries. We have on-site X-ray for immediate diagnosis."
          }
        },
        {
          "@type": "Question",
          "name": "What if I need surgery after my visit?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Our providers include board-certified orthopedic surgeons. If surgery is needed, we coordinate your care directly—no extra referrals or scheduling delays. Many injuries we see can be treated conservatively without surgery."
          }
        },
        {
          "@type": "Question",
          "name": "How long will my visit take?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Most patients are seen, diagnosed, and treated within 60 minutes. Our average wait time is under 15 minutes, compared to 4+ hours at the emergency room."
          }
        },
        {
          "@type": "Question",
          "name": "Do you treat children and adolescents?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, we treat patients of all ages including children and adolescents. Pediatric fractures, sports injuries, and growth plate concerns are common conditions we see at our Draper clinic."
          }
        },
        {
          "@type": "Question",
          "name": "What should I bring to my visit?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Bring your photo ID, insurance card (if applicable), and any relevant medical records or imaging from previous visits. If it's a workplace injury, bring your employer's workers' comp information."
          }
        }
      ]
    }
    </script>
