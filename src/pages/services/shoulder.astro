---
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import '@/styles/global.css';

const faqs = [
  { q: "Can I walk in for shoulder pain without an appointment?", a: "Yes. Instant Orthopedic Care is a walk-in clinic—no appointment or referral needed. We see patients on a first-come, first-served basis with an average wait time under 15 minutes." },
  { q: "How do you diagnose rotator cuff injuries?", a: "We assess strength, range of motion, and functional stability to determine whether you're dealing with a strain, impingement, tendonitis, or a potential tear. When appropriate, we recommend next-step imaging and referral pathways." },
  { q: "Do you offer shoulder injections on-site?", a: "Yes. Targeted injections can reduce inflammation and improve function so you can participate in physical therapy or daily activity with less pain. Injections can be especially helpful for flare-ups that limit sleep or keep you from working." },
  { q: "What should I do if I dislocated my shoulder?", a: "If you felt a pop, noticed sudden deformity, or can't comfortably raise your arm, walk in promptly. We'll evaluate joint integrity and help you understand the safest path to recovery, including return-to-activity planning." },
];
---

<html lang="en">
  <head>
    <!-- Google Tag Manager -->
