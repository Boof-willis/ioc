              </ul>
            </div>
          </div>
        </div>
      </Container>
    </Section>

    <!-- Why Athletes Choose IOC -->
    <Section background="gray" class="py-24">
      <Container>
        <div class="max-w-5xl mx-auto">
          <div class="text-center mb-12">
            <h2 class="text-3xl md:text-4xl font-bold text-slate-900 tracking-tight mb-4">Why athletes choose Instant Orthopedic Care</h2>
