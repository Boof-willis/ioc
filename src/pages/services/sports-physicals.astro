            </div>

            <div class="bg-slate-50 rounded-2xl p-8 border border-slate-100">
              <h3 class="text-xl font-bold text-slate-900 mb-6">Assessment may include</h3>
              <ul class="space-y-3">
                {rtpAssessment.map((item) => (
                  <li class="flex items-start gap-3 text-slate-600">
                    <svg class="w-5 h-5 text-blue-600 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" /></svg>
                    <span>{item}</span>
                  </li>
