                  <li class="flex items-start gap-3 text-slate-600">
                    <svg class="w-5 h-5 text-ioc-green flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                    <span>{item}</span>
                  </li>
