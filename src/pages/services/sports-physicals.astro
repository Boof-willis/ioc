          </div>
          <p class="text-sm text-slate-500 mt-6 font-medium">Same-day appointments and walk-ins available. Most insurance accepted.</p>
        </div>
      </Container>
    </Section>

    <!-- Sports Physicals -->
    <Section background="gray" class="py-24">
      <Container>
        <div class="max-w-5xl mx-auto">
          <div class="text-center mb-12">
            <span class="inline-block text-xs font-bold text-blue-600 uppercase tracking-widest mb-3">Sports Physicals</span>
