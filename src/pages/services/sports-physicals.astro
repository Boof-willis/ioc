---
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import A2PCompliance from '@/components/A2PCompliance.astro';
import '@/styles/global.css';

const faqs = [
  { q: "Do I need an appointment for a sports physical?", a: "No. Sports physicals are walk-in friendly at Instant Orthopedic Care, and same-day appointments are available if you'd prefer to lock in a time. Most physicals are completed in a single visit." },
  { q: "Will you sign my school or league participation forms?", a: "Yes. Our providers complete and sign school, club, and travel team participation forms on the spot, so athletes are ready to start practice or tryouts without delay." },
  { q: "What's the difference between a sports physical and a regular physical?", a: "A sports physical focuses on musculoskeletal readiness for athletic participation—joint mobility, strength, prior injuries, and functional movement. It's not a replacement for a full annual physical with a primary care provider, but it's the right evaluation for sports clearance." },
  { q: "What is a return-to-play assessment?", a: "A return-to-play assessment is a structured evaluation after an injury or surgery to determine whether an athlete is ready to safely resume sport. We look at healing, strength, stability, range of motion, and sport-specific movement before issuing clearance." },
  { q: "Do you treat concussions?", a: "We provide initial concussion screening and guidance. If specialized neurologic care or further imaging is needed, we coordinate referrals so families aren't left navigating the system alone." },
  { q: "How much does a sports physical cost?", a: "Most insurance plans cover sports physicals. We accept most major insurers and offer transparent self-pay pricing for families without coverage. Call (385) 386-7026 to verify your specific plan." },
];

const physicalIncludes = [
  "Review of medical history",
  "Orthopedic and musculoskeletal evaluation",
  "Joint and mobility assessment",
  "Strength and functional movement screening",
  "Injury history review",
  "Completion of school and athletic participation forms",
];

const physicalIdealFor = [
  "School sports participation",
  "Club and travel teams",
  "Recreational athletes",
  "Preseason athletic clearance",
  "Annual athletic physicals",
];

const rtpConditions = [
  "Sprains and strains",
  "Fractures and broken bones",
  "Concussions (initial screening and referral)",
  "Knee injuries",
  "Shoulder injuries",
  "Ankle injuries",
  "Post-surgical recovery progression",
  "Sports-related overuse injuries",
];

const rtpAssessment = [
  "Functional movement testing",
  "Strength and balance evaluation",
  "Range of motion assessment",
  "Sport-specific movement evaluation",
  "X-rays if clinically indicated",
  "Return-to-sport recommendations",
];

const whyChooseUs = [
  "Same-day orthopedic evaluation",
  "Walk-in availability",
  "On-site X-ray",
  "Experienced sports medicine providers",
  "Faster access than the ER or traditional orthopedic offices",
  "Convenient care for athletes, parents, and coaches",
];
