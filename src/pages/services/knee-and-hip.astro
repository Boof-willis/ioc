---
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import Container from '@/components/ui/Container.astro';
import Section from '@/components/ui/Section.astro';
import '@/styles/global.css';

const conditions = [
  { name: "ACL, MCL & Ligament Tears", description: "Early diagnosis allows for proper bracing, stabilization, and referral planning. Delayed care can increase joint damage and prolong recovery." },
  { name: "Meniscus Injuries", description: "Focused assessments to determine whether conservative management or surgical consultation is appropriate for meniscal tears." },
  { name: "Knee & Hip Arthritis", description: "Structured treatment including targeted joint injections, bracing strategies, and recovery plans tailored to each patient's activity level and goals." },
  { name: "Patellar Disorders", description: "Treatment for patellar tendonitis, runner's knee, dislocations, and tracking issues causing anterior knee pain." },
  { name: "Hip Bursitis & Tendonitis", description: "Targeted relief for trochanteric bursitis, hip flexor strains, labral tears, and IT band syndrome with injections and therapy protocols." },
  { name: "Joint Replacement Evaluation", description: "Pre-surgical evaluation and referral for knee and hip replacement when conservative options have been exhausted." },
];

const faqs = [
  { q: "Can I walk in for knee or hip pain without an appointment?", a: "Yes. Instant Orthopedic Care is a walk-in clinic—no appointment or referral needed. Instead of waiting weeks to see a specialist, patients can walk in and receive comprehensive joint evaluation immediately." },
  { q: "How do you diagnose ligament tears?", a: "Ligament tears often present with swelling, instability, or a popping sensation. Our orthopedic providers perform focused assessments and use on-site X-ray to evaluate. If an MRI is needed, we can order one and review results quickly." },
  { q: "Do you offer knee and hip injections?", a: "Yes. We offer targeted joint injections, bracing strategies, and structured recovery plans. Treatment plans may include injections that dramatically improve mobility and comfort." },
  { q: "What areas do you serve?", a: "Our Draper clinic serves patients throughout Salt Lake County and Utah County, including Sandy, South Jordan, Riverton, Lehi, Alpine, and surrounding communities." },
];
---

<html lang="en">
