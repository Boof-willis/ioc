    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "When should I see an orthopedist for knee pain in Utah?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "If knee pain persists for more than a few days, causes swelling, instability, locking, or limits walking, a same-day orthopedic evaluation can help identify the cause and guide treatment."
          }
        },
        {
          "@type": "Question",
          "name": "What are signs of an ACL or meniscus injury?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Common signs include a popping sensation at injury, swelling, instability, pain with twisting, or locking/catching. Early evaluation helps prevent further joint damage."
          }
        },
        {
          "@type": "Question",
          "name": "Is hip pain always arthritis?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No. Hip pain can also be caused by bursitis, muscle strain, labral tears, or other conditions. A focused orthopedic exam helps identify likely causes and next steps."
          }
        },
        {
          "@type": "Question",
          "name": "Can joint injections help knee or hip pain?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Injections may reduce inflammation and improve function for certain conditions. Your provider will determine whether injections are appropriate based on symptoms and exam findings."
          }
        }
      ]
    }
    </script>

    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
