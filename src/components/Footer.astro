---
import Container from '@/components/ui/Container.astro';
---

<footer class="bg-slate-900 text-white">
  <Container>
    <div class="py-12 grid grid-cols-2 md:grid-cols-4 gap-8">
      <!-- About -->
      <div class="col-span-2 md:col-span-1">
        <img 
          src="https://pub-6e52b1646d124a3f98c52980e22c87e2.r2.dev/Untitled%20design%20(49).png" 
          alt="Instant Orthopedic Care – Orthopedic Urgent Care Clinic in Draper, Utah" 
          class="w-[110px] h-auto mb-4"
          loading="lazy"
        />
        <p class="text-slate-400 text-sm leading-relaxed">
          Expert orthopedic care without the wait. Walk in or book online today.
        </p>
      </div>

      <!-- Services -->
      <div>
        <h4 class="font-semibold mb-4">Services</h4>
        <ul class="space-y-2 text-sm text-slate-400">
          <li><a href="/services/ankle-and-foot" class="hover:text-white transition-colors">Ankle & Foot</a></li>
          <li><a href="/services/knee-and-hip" class="hover:text-white transition-colors">Knee & Hip</a></li>
          <li><a href="/services/shoulder" class="hover:text-white transition-colors">Shoulder</a></li>
          <li><a href="/services/elbow-and-wrist" class="hover:text-white transition-colors">Elbow & Wrist</a></li>
          <li><a href="/services/sports-injuries" class="hover:text-white transition-colors">Sports Injuries</a></li>
          <li><a href="/services/chronic-pain" class="hover:text-white transition-colors">Chronic Pain</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="font-semibold mb-4">Contact</h4>
        <ul class="space-y-2 text-sm text-slate-400">
          <li>
            <a href="tel:3853867026" class="hover:text-white transition-colors">
              (385) 386-7026
            </a>
          </li>
          <li>
            <a href="mailto:info@instantorthocare.com" class="hover:text-white transition-colors">
              info@instantorthocare.com
            </a>
          </li>
          <li class="leading-relaxed">
            75 E 12300 S Suite 100<br />
            Draper, UT 84020
          </li>
          <li class="pt-2">
            <span class="text-ioc-green font-semibold">Walk-ins welcome</span>
          </li>
        </ul>
      </div>

      <!-- Information -->
      <div class="col-span-2 md:col-span-1">
        <h4 class="font-semibold mb-4">Information</h4>
        <ul class="space-y-2 text-sm text-slate-400">
          <li><a href="/team" class="hover:text-white transition-colors">Our Team</a></li>
          <li><a href="/#location" class="hover:text-white transition-colors">Location & Hours</a></li>
          <li><a href="https://pp-wfe-101.advancedmd.com/163338/onlineintake/demographic" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">Book Online</a></li>
          <li><a href="https://pp-wfe-102.advancedmd.com/156528/account/logon" target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">Patient Login</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-slate-800 py-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-sm text-slate-500">
      <p>&copy; {new Date().getFullYear()} Instant Orthopedic Care. All rights reserved.</p>
      <div class="flex items-center gap-4">
        <a href="/privacy-policy" class="hover:text-white transition-colors">Privacy Policy</a>
        <a href="/terms-of-service" class="hover:text-white transition-colors">Terms of Service</a>
      </div>
    </div>
  </Container>
</footer>

