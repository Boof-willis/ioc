<!-- Navigation (Above hero) -->
<nav class:list={[
  "sticky top-0 z-50 transition-all duration-300 w-[calc(100%-2rem)] max-w-[1400px] mx-auto",
  transparent ? "bg-transparent" : "bg-white"
]}>
  <div class="w-full mx-auto px-0">
    <div class="flex justify-between items-center h-20">
      <!-- Logo -->
      <div class="flex items-center">
        <a href="/" class="flex items-center flex-shrink-0">
          <img 
            src="https://pub-6e52b1646d124a3f98c52980e22c87e2.r2.dev/Untitled%20design%20(49).png" 
            alt="Instant Orthopedic Care Logo" 
            width="150"
            height="auto"
            loading="eager"
            fetchpriority="high"
            decoding="sync"
            class="h-auto w-[150px]"
          />
        </a>
      </div>

      <!-- Desktop Menu -->
      <div class="hidden md:flex items-center space-x-8">
        <a href="/#services" class="text-sm font-bold text-slate-600 hover:text-blue-600 transition-colors">Services</a>
        <a href="/team" class="text-sm font-bold text-slate-600 hover:text-blue-600 transition-colors">Our Team</a>
        <a href="/#insurance" class="text-sm font-bold text-slate-600 hover:text-blue-600 transition-colors">Insurance</a>
        <a href="/#location" class="text-sm font-bold text-slate-600 hover:text-blue-600 transition-colors">Location</a>
        <a href="/#testimonials" class="text-sm font-bold text-slate-600 hover:text-blue-600 transition-colors">Reviews</a>
